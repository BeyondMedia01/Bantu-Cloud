{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Bantu",
  "version": "0.1.0",
  "identifier": "com.bantu.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "title": "Bantu",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://bantu-cloud.onrender.com/api/desktop/updates?target={{target}}&arch={{arch}}&current_version={{current_version}}"],
      "dialog": true,
      "pubkey": "dHJ1c3RlZCBjb21tZW50OiBiYW50dS1kZXNrdG9wLXNpZ25pbmcta2V5CmNqSkl2SHVrbTNzT1QxcG43NDBrektUZzA5d1owNm85Z2R2bDhJckZNK0E9"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/backend"],
    "resources": ["resources/template.db"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
