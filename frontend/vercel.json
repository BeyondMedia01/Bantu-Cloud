{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://localhost:5005/api/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "http://localhost:5005/uploads/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
