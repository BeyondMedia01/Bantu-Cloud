generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(uuid())
  name                String?
  email               String              @unique
  password            String
  role                UserRole            @default(EMPLOYEE)
  emailVerified       DateTime?
  image               String?
  passwordResetToken  String?             @unique
  passwordResetExpiry DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  firstName           String?
  lastName            String?
  phone               String?
  preferences         Json?               @default("{}")
  totpSecret          String?
  totpEnabled         Boolean             @default(false)
  clientAdmin         ClientAdmin?
  employee            Employee?
  Expense             Expense[]
  PerformanceReview   PerformanceReview[]
  sessions            Session[]
  refreshTokens       RefreshToken[]
  UserCompanyRole     UserCompanyRole[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Client {
  id               String            @id @default(uuid())
  name             String
  taxId            String?
  email            String?
  phone            String?
  address          String?
  isActive         Boolean           @default(true)
  defaultCurrency  String            @default("USD")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  enabledModules   AppModule[]       @default([])
  clientAdmins     ClientAdmin[]
  companies        Company[]
  employees        Employee[]
  grades           Grade[]
  license          LicenseToken?
  necTables        NecTable[]
  payrollCalendars PayrollCalendar[]
  subCompanies     SubCompany[]
  subscription     Subscription?
  taxTables        TaxTable[]
  transactionCodes TransactionCode[]
}

model ClientAdmin {
  id        String   @id @default(uuid())
  userId    String   @unique
  clientId  String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Company {
  id                     String                  @id @default(uuid())
  clientId               String
  name                   String
  registrationNumber     String?
  taxId                  String?
  address                String?
  contactEmail           String?
  contactPhone           String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  sdfRate                Float?
  wcifRate               Float?
  zimdefRate             Float?
  nssaNumber             String?
  Asset                  Asset[]
  AssetCategory          AssetCategory[]
  attendanceLogs         AttendanceLog[]
  attendanceRecords      AttendanceRecord[]
  biometricDevices       BiometricDevice[]
  branches               Branch[]
  client                 Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  currencyRates          CurrencyRate[]
  departments            Department[]
  employees              Employee[]
  Expense                Expense[]
  ExpenseCategory        ExpenseCategory[]
  Invite                 Invite[]
  JobPosting             JobPosting[]
  leaveBalances          LeaveBalance[]
  leaveEncashments       LeaveEncashment[]
  leavePolicies          LeavePolicy[]
  leaveTypes             LeaveType[]
  leavePolicyAssignments LeavePolicyAssignment[]
  Onboarding             Onboarding[]
  OnboardingTemplate     OnboardingTemplate[]
  payrollCores           PayrollCore[]
  payrollRuns            PayrollRun[]
  PerformanceGoal        PerformanceGoal[]
  PerformanceReview      PerformanceReview[]
  Role                   Role[]
  shifts                 Shift[]
  shiftAssignments       ShiftAssignment[]
  SuccessionPlan         SuccessionPlan[]
  Survey                 Survey[]
  TrainingCourse         TrainingCourse[]
  UserCompanyRole        UserCompanyRole[]
  payrollUsers           PayrollUser[]
  payrollLogs            PayrollLog[]
}

model SubCompany {
  id        String   @id @default(uuid())
  clientId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Branch {
  id           String       @id @default(uuid())
  companyId    String
  subCompanyId String?
  name         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subCompany   SubCompany?  @relation(fields: [subCompanyId], references: [id])
  departments  Department[]
  employees    Employee[]
}

model Department {
  id        String     @id @default(uuid())
  companyId String
  branchId  String?
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  branch    Branch?    @relation(fields: [branchId], references: [id])
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
}

model Employee {
  id                     String                  @id @default(uuid())
  clientId               String
  companyId              String
  branchId               String?
  departmentId           String?
  userId                 String?                 @unique
  employeeCode           String?
  firstName              String
  lastName               String
  maidenName             String?
  dateOfBirth            DateTime?
  gender                 Gender?
  maritalStatus          MaritalStatus?
  nationality            String?
  socialSecurityNum      String?
  homeAddress            String?
  postalAddress          String?
  nextOfKin              String?
  nextOfKinName          String?
  nextOfKinContact       String?
  title                  String?
  occupation             String?
  position               String
  employmentType         EmploymentType          @default(PERMANENT)
  startDate              DateTime
  costCenter             String?
  leaveEntitlement       Float?
  dischargeDate          DateTime?
  dischargeReason        String?
  baseRate               Float
  currency               String                  @default("USD")
  paymentMethod          PaymentMethod           @default(BANK)
  paymentBasis           PaymentBasis            @default(MONTHLY)
  hoursPerPeriod         Float?
  daysPerPeriod          Float?
  bankName               String?
  bankBranch             String?
  accountNumber          String?
  rateSource             RateSource              @default(MANUAL)
  gradeId                String?
  taxMethod              TaxMethod               @default(NON_FDS)
  taxTable               String?
  taxDirective           String?
  taxDirectivePerc       Float?
  taxDirectiveAmt        Float?
  accumulativeSetting    String?
  taxCredits             Float?
  tin                    String?
  motorVehicleBenefit    Float                   @default(0)
  motorVehicleType       String?
  leaveBalance           Float                   @default(0)
  leaveTaken             Float                   @default(0)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  vehicleEngineCategory  VehicleEngineCategory   @default(NONE)
  grossingUp             Boolean                 @default(false)
  email                  String?
  nationalId             String?
  necGradeId             String?
  passportNumber         String?
  pensionNumber          String?
  phone                  String?
  splitUsdPercent        Float?
  splitZigMode           SplitZigMode            @default(NONE)
  splitZigValue          Float?
  taxDirectiveEffective  DateTime?
  taxDirectiveExpiry     DateTime?
  taxDirectiveRef        String?
  Asset                  Asset[]
  attendanceLogs         AttendanceLog[]
  attendanceRecords      AttendanceRecord[]
  branch                 Branch?                 @relation(fields: [branchId], references: [id])
  client                 Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department             Department?             @relation(fields: [departmentId], references: [id])
  grade                  Grade?                  @relation(fields: [gradeId], references: [id])
  necGrade               NecGrade?               @relation(fields: [necGradeId], references: [id])
  user                   User?                   @relation(fields: [userId], references: [id])
  bankAccounts           EmployeeBankAccount[]
  documents              EmployeeDocument[]
  salaryStructure        EmployeeTransaction[]
  Expense                Expense[]
  leaveBalances          LeaveBalance[]
  leaveEncashments       LeaveEncashment[]
  leaveRecords           LeaveRecord[]
  leaveRequests          LeaveRequest[]
  loans                  Loan[]
  Onboarding             Onboarding[]
  payrollCores           PayrollCore[]
  payrollInputs          PayrollInput[]
  payrollTransactions    PayrollTransaction[]
  payslips               Payslip[]
  PerformanceGoal        PerformanceGoal[]
  PerformanceReview      PerformanceReview[]
  shiftAssignments       ShiftAssignment[]
  SuccessionCandidate    SuccessionCandidate[]
  SurveyResponse         SurveyResponse[]
  TrainingCertificate    TrainingCertificate[]
  TrainingEnrollment     TrainingEnrollment[]
  leaveTransactions      LeaveTransaction[]
  leaveAllocations       LeaveAllocation[]
  leavePolicyAssignments LeavePolicyAssignment[]

  @@unique([clientId, employeeCode])
  @@index([companyId])
  @@index([clientId])
  @@index([branchId])
  @@index([departmentId])
  @@index([gradeId])
  @@index([necGradeId])
  @@index([clientId, companyId])
  @@index([companyId, employmentType])
  @@index([companyId, dischargeDate])
  @@index([companyId, dischargeDate, paymentMethod])
}

model EmployeeBankAccount {
  id            String   @id @default(uuid())
  employeeId    String
  accountName   String?
  accountNumber String
  bankName      String
  bankBranch    String?
  branchCode    String?
  currency      String   @default("USD")
  splitType     String   @default("REMAINDER")
  splitValue    Float    @default(0)
  priority      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model PayrollUser {
  id                String    @id @default(uuid())
  companyId         String
  fullName          String
  email             String
  role              String    @default("VIEWER")
  isActive          Boolean   @default(true)
  canProcessPayroll Boolean   @default(false)
  canEditEmployees  Boolean   @default(false)
  canViewReports    Boolean   @default(false)
  canExportData     Boolean   @default(false)
  lastLogin         DateTime?
  createdBy         String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logs    PayrollLog[]

  @@index([companyId])
  @@index([email])
}

model PayrollLog {
  id              String   @id @default(uuid())
  companyId       String
  userId          String?
  actionType      String
  entityAffected  String
  entityId        String?
  oldValue        String?
  newValue        String?
  ipAddress       String?
  status          String   @default("SUCCESS")
  errorMessage    String?
  notes           String?
  actionTimestamp DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrollUser PayrollUser? @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([actionTimestamp])
}

model EmployeeDocument {
  id         String   @id @default(uuid())
  employeeId String
  name       String
  fileUrl    String
  type       String
  size       Int?
  mimeType   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model PayrollCore {
  id                     String   @id @default(uuid())
  companyId              String
  employeeId             String
  fullName               String
  employeeCode           String
  jobTitle               String?
  basicSalaryZiG         Float    @default(0)
  basicSalaryUSD         Float    @default(0)
  preferredCurrencySplit Json?
  paymentFrequency       String   @default("MONTHLY")
  bankName               String?
  bankBranch             String?
  accountNumber          String?
  startDate              DateTime
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee               Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model PayrollCalendar {
  id          String       @id @default(uuid())
  clientId    String
  periodType  String       @default("MONTHLY")
  year        Int
  month       Int?
  payDay      Int
  startDate   DateTime
  endDate     DateTime
  isClosed    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payrollRuns PayrollRun[]

  @@unique([clientId, year, month])
}

model PayrollRun {
  id                String               @id @default(uuid())
  payrollCalendarId String?
  companyId         String
  runDate           DateTime             @default(now())
  startDate         DateTime
  endDate           DateTime
  currency          String               @default("USD")
  exchangeRate      Float                @default(1)
  status            PayrollStatus        @default(DRAFT)
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  dualCurrency      Boolean              @default(false)
  Expense           Expense[]
  loanRepayments    LoanRepayment[]
  payrollInputs     PayrollInput[]
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrollCalendar   PayrollCalendar?     @relation(fields: [payrollCalendarId], references: [id])
  transactions      PayrollTransaction[]
  payslips          Payslip[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, status, runDate])
  @@index([payrollCalendarId])
}

model PayrollTransaction {
  id                String          @id @default(uuid())
  employeeId        String
  payrollRunId      String
  transactionCodeId String
  amount            Float
  currency          String          @default("USD")
  description       String?
  createdAt         DateTime        @default(now())
  employee          Employee        @relation(fields: [employeeId], references: [id])
  payrollRun        PayrollRun      @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  transactionCode   TransactionCode @relation(fields: [transactionCodeId], references: [id])

  @@index([payrollRunId])
  @@index([employeeId])
  @@index([transactionCodeId])
}

model PayrollInput {
  id                String          @id @default(uuid())
  employeeId        String
  payrollRunId      String?
  transactionCodeId String
  period            String
  processed         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  balance           Float           @default(0)
  duration          String          @default("Indefinite")
  employeeUSD       Float           @default(0)
  employeeZiG       Float           @default(0)
  employerUSD       Float           @default(0)
  employerZiG       Float           @default(0)
  notes             String?
  units             Float?
  unitsType         String?
  employee          Employee        @relation(fields: [employeeId], references: [id])
  payrollRun        PayrollRun?     @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  transactionCode   TransactionCode @relation(fields: [transactionCodeId], references: [id])

  @@index([employeeId])
  @@index([payrollRunId])
  @@index([transactionCodeId])
  @@index([payrollRunId, employeeId])
  @@index([period])
  @@index([employeeId, period])
  @@index([period, processed])
}

model Payslip {
  id                 String     @id @default(uuid())
  employeeId         String
  payrollRunId       String
  gross              Float
  paye               Float
  aidsLevy           Float      @default(0)
  nssaEmployee       Float      @default(0)
  loanDeductions     Float      @default(0)
  netPay             Float
  pdfUrl             String?
  createdAt          DateTime   @default(now())
  aidsLevyUSD        Float?
  aidsLevyZIG        Float?
  basicSalaryApplied Float      @default(0)
  exemptBonus        Float?     @default(0)
  exemptBonusUSD     Float?     @default(0)
  exemptBonusZIG     Float?     @default(0)
  exemptSeverance    Float?     @default(0)
  grossUSD           Float?
  grossZIG           Float?
  medicalAidCredit   Float?     @default(0)
  necEmployer        Float      @default(0)
  necLevy            Float      @default(0)
  netPayUSD          Float?
  netPayZIG          Float?
  nssaBasis          Float      @default(0)
  nssaEmployer       Float      @default(0)
  nssaUSD            Float?
  nssaZIG            Float?
  payeUSD            Float?
  payeZIG            Float?
  pensionApplied     Float      @default(0)
  sdfContribution    Float      @default(0)
  taxCreditsApplied  Float?     @default(0)
  wcifEmployer       Float      @default(0)
  zimdefEmployer     Float      @default(0)
  exemptSeveranceUSD Float?     @default(0)
  exemptSeveranceZIG Float?     @default(0)
  exchangeRate       Float?
  employee           Employee   @relation(fields: [employeeId], references: [id])
  payrollRun         PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([employeeId, payrollRunId])
  @@index([employeeId])
  @@index([payrollRunId])
}

model TransactionCode {
  id                   String                @id @default(uuid())
  clientId             String
  code                 String
  name                 String
  description          String?
  type                 TransactionType       @default(EARNING)
  taxable              Boolean               @default(true)
  pensionable          Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deemedBenefitPercent Float?
  affectsAidsLevy      Boolean               @default(true)
  affectsNssa          Boolean               @default(true)
  affectsPaye          Boolean               @default(true)
  calculationType      String                @default("fixed")
  defaultValue         Float?
  formula              String?
  incomeCategory       IncomeCategory?
  isActive             Boolean               @default(true)
  preTax               Boolean               @default(false)
  employeeDefaults     EmployeeTransaction[]
  inputs               PayrollInput[]
  transactions         PayrollTransaction[]
  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rules                TransactionCodeRule[]

  @@unique([clientId, code])
}

model TransactionCodeRule {
  id                  String          @id @default(uuid())
  transactionCodeId   String
  conditionType       String
  conditionValue      String?
  calculationOverride String?
  valueOverride       Float?
  formulaOverride     String?
  capAmount           Float?
  priority            Int             @default(0)
  description         String?
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  transactionCode     TransactionCode @relation(fields: [transactionCodeId], references: [id], onDelete: Cascade)

  @@index([transactionCodeId])
}

model EmployeeTransaction {
  id                String          @id @default(uuid())
  employeeId        String
  transactionCodeId String
  value             Float
  currency          String          @default("USD")
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  isRecurring       Boolean         @default(true)
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  transactionCode   TransactionCode @relation(fields: [transactionCodeId], references: [id])

  @@index([employeeId])
  @@index([transactionCodeId])
  @@index([effectiveFrom, effectiveTo])
}

model TaxTable {
  id            String       @id @default(uuid())
  clientId      String
  name          String
  currency      String       @default("USD")
  effectiveDate DateTime
  expiryDate    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  isActive      Boolean      @default(false)
  isAnnual      Boolean      @default(true)
  brackets      TaxBracket[]
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model TaxBracket {
  id          String   @id @default(uuid())
  taxTableId  String
  lowerBound  Float
  upperBound  Float?
  rate        Float
  fixedAmount Float    @default(0)
  createdAt   DateTime @default(now())
  taxTable    TaxTable @relation(fields: [taxTableId], references: [id], onDelete: Cascade)

  @@index([taxTableId])
}

model Grade {
  id        String     @id @default(uuid())
  clientId  String
  name      String
  minRate   Float
  maxRate   Float
  currency  String     @default("USD")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model NecTable {
  id            String     @id @default(uuid())
  clientId      String
  name          String
  sector        String
  currency      String     @default("USD")
  effectiveDate DateTime
  expiryDate    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  grades        NecGrade[]
  client        Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model NecGrade {
  id          String     @id @default(uuid())
  necTableId  String
  gradeCode   String
  description String?
  minRate     Float
  necLevyRate Float      @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
  necTable    NecTable   @relation(fields: [necTableId], references: [id], onDelete: Cascade)

  @@index([necTableId])
}

model Shift {
  id                String             @id @default(uuid())
  companyId         String
  name              String
  code              String?
  startTime         String
  endTime           String
  breakMinutes      Int                @default(60)
  normalHours       Float              @default(8)
  ot0Threshold      Float              @default(0)
  ot1Threshold      Float              @default(2)
  ot0Multiplier     Float              @default(1.0)
  ot1Multiplier     Float              @default(1.5)
  ot2Multiplier     Float              @default(2.0)
  isOvernight       Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments       ShiftAssignment[]
}

model ShiftAssignment {
  id         String    @id @default(uuid())
  employeeId String
  shiftId    String
  companyId  String
  startDate  DateTime
  endDate    DateTime?
  daysOfWeek String
  isActive   Boolean   @default(true)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift      Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([employeeId, startDate])
  @@index([companyId, startDate])
}

model BiometricDevice {
  id             String          @id @default(uuid())
  companyId      String
  name           String
  vendor         String
  model          String?
  ipAddress      String?
  port           Int?            @default(4370)
  serialNumber   String?
  location       String?
  username       String?
  password       String?
  webhookKey     String?
  isActive       Boolean         @default(true)
  lastSyncAt     DateTime?
  lastSyncStatus String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  logs           AttendanceLog[]
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AttendanceLog {
  id           String           @id @default(uuid())
  companyId    String
  employeeId   String?
  deviceId     String?
  deviceUserId String?
  punchTime    DateTime
  punchType    String
  source       String           @default("DEVICE")
  rawPayload   Json?
  processed    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  device       BiometricDevice? @relation(fields: [deviceId], references: [id])
  employee     Employee?        @relation(fields: [employeeId], references: [id])

  @@index([companyId, punchTime])
  @@index([employeeId, punchTime])
}

model AttendanceRecord {
  id               String    @id @default(uuid())
  employeeId       String
  companyId        String
  date             DateTime
  shiftId          String?
  clockIn          DateTime?
  clockOut         DateTime?
  breakMinutes     Int       @default(0)
  totalMinutes     Int       @default(0)
  normalMinutes    Int       @default(0)
  ot0Minutes       Int       @default(0)
  ot1Minutes       Int       @default(0)
  ot2Minutes       Int       @default(0)
  status           String    @default("PRESENT")
  isPublicHoliday  Boolean   @default(false)
  isManualOverride Boolean   @default(false)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift            Shift?    @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, date])
  @@index([companyId, date])
  @@index([shiftId])
}

model LeavePolicy {
  id              String                  @id @default(uuid())
  companyId       String
  leaveTypeId     String
  accrualRate     Float                   @default(2.5)
  entitlementDays Float                   @default(0)
  maxAccumulation Float                   @default(0)
  carryOverLimit  Float                   @default(30)
  encashable      Boolean                 @default(true)
  encashCap       Float                   @default(0)
