DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bantu_payroll?schema=public"
# Direct (non-pooler) connection — used by Prisma migrations to avoid advisory lock timeouts.
# On Neon: same as DATABASE_URL but remove "-pooler" from the hostname.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bantu_payroll?schema=public"
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
PORT=5005
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email / SMTP (required for notifications, password reset, payslip delivery)
# Works with any SMTP provider: SendGrid, Mailgun, Resend, Gmail, etc.
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey, SMTP_PASS=<api-key>
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="Bantu Payroll <no-reply@yourdomain.com>"

# Cron secret — required for /api/cron/* endpoints
CRON_SECRET="replace-with-a-long-random-secret"

# Trial & Upgrade notifications
UPGRADE_CONTACT_EMAIL=bechanibeyond@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
